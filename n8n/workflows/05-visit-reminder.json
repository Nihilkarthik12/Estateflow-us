            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Any Visits Tomorrow?": {
      "main": [
        [
          {
            "node": "Split Visits",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Split Visits": {
      "main": [
        [
          {
            "node": "Build Reminder Message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build Reminder Message": {
      "main": [

            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "description": "Runs every morning at 8 AM. Sends WhatsApp and email reminder to every visitor whose site visit is scheduled for tomorrow."
  }

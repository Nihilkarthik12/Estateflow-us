          }
        }
      },
      "id": "log-conversation",
      "name": "Log Follow-up in CRM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1560,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://estateflow-us.vercel.app/api/n8n/send-email",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-n8n-secret",
              "value": "estateflow-us-n8n-secret-2026"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "to",
              "value": "={{ $('Split Into Individual Leads').item.json.email }}"
            },
            {
              "name": "subject",
              "value": "Following up on your property search"
            },
            {
              "name": "body",
              "value": "={{ $('Generate AI Follow-up Message').item.json.message }}"
            },
            {
              "name": "lead_id",
              "value": "={{ $('Split Into Individual Leads').item.json.id }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "send-email-followup",
      "name": "Send Email Follow-up",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1340,
        380
      ]
    }
  ],
  "connections": {
    "Daily 9AM (Mon-Sat)": {
      "main": [
        [
          {
            "node": "Get Leads Needing Follow-up",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Leads Needing Follow-up": {
      "main": [
        [
          {
            "node": "Any Leads to Follow Up?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Any Leads to Follow Up?": {
      "main": [
        [
          {
            "node": "Split Into Individual Leads",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Split Into Individual Leads": {
      "main": [
        [
          {
            "node": "Generate AI Follow-up Message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Generate AI Follow-up Message": {
      "main": [
        [
          {
            "node": "Send WhatsApp Follow-up",
            "type": "main",
            "index": 0
          },
          {
            "node": "Send Email Follow-up",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send WhatsApp Follow-up": {
      "main": [
        [
          {
            "node": "Log Follow-up in CRM",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "description": "Runs every morning Mon-Sat at 9 AM. Fetches leads that need follow-up based on their pipeline stage, generates a personalized AI message, sends it via WhatsApp, and logs it in the CRM."
  }
}